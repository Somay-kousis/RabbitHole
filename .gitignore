```gitignore
# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# ==========================================
# Virtual Environment
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# Environment Variables
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# Logs
# ==========================================
logs/
*.log

# ==========================================
# Testing
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# ==========================================
# Jupyter
# ==========================================
.ipynb_checkpoints/

# ==========================================
# VSCode
# ==========================================
.vscode/

# ==========================================
# MacOS
# ==========================================
.DS_Store

# ==========================================
# Vector Databases
# ==========================================
chroma/
vectorstore/
vectorstores/
faiss_index/
qdrant_data/

# ==========================================
# Data
# ==========================================
data/raw/
data/processed/
data/vectorstores/

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/vectorstores/.gitkeep

# ==========================================
# Cache
# ==========================================
.cache/
.cache*/
temp/
tmp/

# ==========================================
# SQLite
# ==========================================
*.db
*.sqlite
*.sqlite3

# ==========================================
# LangGraph
# ==========================================
.langgraph_api/
langgraph.db

# ==========================================
# LlamaIndex
# ==========================================
storage/
persist/
index_storage/

# ==========================================
# Terraform
# ==========================================
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

# ==========================================
# Docker
# ==========================================
docker-data/

# ==========================================
# Secrets
# ==========================================
secrets/
credentials/
service-account.json

# ==========================================
# Coverage
# ==========================================
coverage.xml

# ==========================================
# IDEs
# ==========================================
.idea/

# ==========================================
# Node (for frontend repo)
# ==========================================
node_modules/
.next/
out/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Misc
# ==========================================
*.bak
*.swp
*.swo

# ==========================================
# Keep placeholders
# ==========================================
!.gitkeep
```

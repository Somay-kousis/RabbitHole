# RabbitHole model mode
# local = use Ollama models running on your machine
# remote = use Groq hosted models
RABBITHOLE_MODEL_MODE=local

# Local Ollama models
LOCAL_MODERATOR_MODEL=gemma4
LOCAL_PERSPECTIVE_MODEL=qwen3.6
LOCAL_SESSION_MODEL=gemma4
LOCAL_JUDICIARY_MODEL=gemma4
LOCAL_QUERY_REFINE_MODEL=gemma4
LOCAL_CONCLUSION_MODEL=qwen3.6

# Remote Groq models
# Required only when RABBITHOLE_MODEL_MODE=remote
GROQ_API_KEY=
REMOTE_MODERATOR_MODEL=llama-3.1-8b-instant
REMOTE_PERSPECTIVE_MODEL=llama-3.3-70b-versatile
REMOTE_SESSION_MODEL=llama-3.1-8b-instant
REMOTE_JUDICIARY_MODEL=llama-3.3-70b-versatile
REMOTE_QUERY_REFINE_MODEL=llama-3.1-8b-instant
REMOTE_CONCLUSION_MODEL=llama-3.3-70b-versatile
